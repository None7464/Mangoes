    }

    static void typeString(String s) {
        for (char c : s.toCharArray()) {
            boolean upper = Character.isUpperCase(c);
            int     vk    = KeyEvent.getExtendedKeyCodeForChar(Character.toLowerCase(c));
            if (vk == KeyEvent.VK_UNDEFINED) continue;
            if (upper) robot.keyPress(KeyEvent.VK_SHIFT);
            robot.keyPress(vk); sleepMs(28); robot.keyRelease(vk);
            if (upper) robot.keyRelease(KeyEvent.VK_SHIFT);
            sleepMs(18);
        }
    }

    static void sendDiscordScreenshot(String url, String content, BufferedImage img) {
        try {
            ByteArrayOutputStream baos = new ByteArrayOutputStream();
            ImageIO.write(img, "png", baos);
            byte[] imgBytes = baos.toByteArray();
            String boundary = "----SPMBoundary" + System.currentTimeMillis();
            HttpURLConnection conn = (HttpURLConnection) new URL(url).openConnection();
            conn.setDoOutput(true); conn.setRequestMethod("POST");
            conn.setRequestProperty("Content-Type", "multipart/form-data; boundary=" + boundary);
            OutputStream out = conn.getOutputStream();
            PrintWriter  pw  = new PrintWriter(new OutputStreamWriter(out, StandardCharsets.UTF_8), true);
            pw.append("--").append(boundary).append("\r\n");
            pw.append("Content-Disposition: form-data; name=\"payload_json\"\r\n\r\n");
            pw.append("{\"content\":\"").append(content.replace("\"","\\\"")).append("\"}\r\n");
            pw.append("--").append(boundary).append("\r\n");
            pw.append("Content-Disposition: form-data; name=\"file\"; filename=\"screenshot.png\"\r\n");
            pw.append("Content-Type: image/png\r\n\r\n");
            pw.flush(); out.write(imgBytes); out.flush();
            pw.append("\r\n--").append(boundary).append("--\r\n"); pw.flush();
            conn.getResponseCode(); conn.disconnect();
        } catch (Exception e) { e.printStackTrace(); }
    }


    static void runItemWebhook() {
        String url = webhookField != null ? webhookField.getText().trim() : savedWebhook;
        String raw = itemNamesField != null ? itemNamesField.getText().trim() : savedItems;
        if (raw.isEmpty() || url.isEmpty()) return;
        String[] items = Arrays.stream(raw.split(","))
                               .map(String::trim).filter(s -> !s.isEmpty()).toArray(String[]::new);
        for (int i = 0; i < items.length; i++) {
            String item = items[i];
            sleepMs(300);
            if (i == 0 && itemGuiX >= 0) { mouseClick(itemGuiX, itemGuiY); sleepMs(500); }
            if (searchBarX >= 0) { mouseClick(searchBarX, searchBarY); sleepMs(200); }
            for (int b = 0; b < 100; b++) { robot.keyPress(KeyEvent.VK_BACK_SPACE); sleepMs(8); robot.keyRelease(KeyEvent.VK_BACK_SPACE); }
            sleepMs(100);
            typeString(item);
            sleepMs(700);
            Dimension sz = Toolkit.getDefaultToolkit().getScreenSize();
            sendDiscordScreenshot(url, "Item: **" + item + "**", robot.createScreenCapture(new Rectangle(sz)));
        }
        // Click item exit if set
        if (itemExitX >= 0) { sleepMs(300); mouseClick(itemExitX, itemExitY); }
    }


    static void pickCoord(int type) {
        frame.setVisible(false);
        JFrame ov = new JFrame();
        ov.setUndecorated(true); ov.setAlwaysOnTop(true);
        try { ov.setOpacity(0.01f); } catch (Exception ignored) {}
        Dimension sc = Toolkit.getDefaultToolkit().getScreenSize();
        ov.setBounds(0, 0, sc.width, sc.height);
        ov.setCursor(Cursor.getPredefinedCursor(Cursor.CROSSHAIR_CURSOR));
        ov.addMouseListener(new MouseAdapter() {
            public void mouseClicked(MouseEvent e) {
                int x = e.getXOnScreen(), y = e.getYOnScreen();
                if      (type == 0) { itemGuiX   = x; itemGuiY   = y; itemGuiLabel.setText(x+", "+y); }
                else if (type == 1) { searchBarX = x; searchBarY = y; searchBarLabel.setText(x+", "+y); }
                else                { itemExitX  = x; itemExitY  = y; itemExitLabel.setText(x+", "+y); }
                ov.dispose(); frame.setVisible(true);
            }
        });
        ov.setVisible(true);
    }

    static String between(String s, String after, String before) {
        int a = s.indexOf(after); if (a < 0) return null;
        a += after.length();
        if (before == null) return s.substring(a);
        int b = s.indexOf(before, a);
        return b < 0 ? s.substring(a) : s.substring(a, b);
    }

    static int matchingBrace(String s, int open) {
        char cl = s.charAt(open) == '{' ? '}' : ']'; int depth = 0;
        for (int i = open; i < s.length(); i++) {
            if (s.charAt(i) == s.charAt(open)) depth++;
            else if (s.charAt(i) == cl) { depth--; if (depth == 0) return i; }
        }
        return -1;
    }


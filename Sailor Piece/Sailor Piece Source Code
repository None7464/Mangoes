        String itemsVal   = itemNamesField != null ? itemNamesField.getText().trim() : savedItems;

        StringBuilder sb = new StringBuilder();
        sb.append("{\n");
        sb.append("  \"activeProfile\": ").append(activeIdx).append(",\n");
        sb.append("  \"uiColor\": \"").append(colorToHex(ACCENT)).append("\",\n");
        sb.append("  \"webhook\": \"").append(escJson(webhookVal)).append("\",\n");
        sb.append("  \"items\": \"").append(escJson(itemsVal)).append("\",\n");
        sb.append("  \"itemGuiX\": ").append(itemGuiX).append(",\n");
        sb.append("  \"itemGuiY\": ").append(itemGuiY).append(",\n");
        sb.append("  \"searchBarX\": ").append(searchBarX).append(",\n");
        sb.append("  \"searchBarY\": ").append(searchBarY).append(",\n");
        sb.append("  \"itemExitX\": ").append(itemExitX).append(",\n");
        sb.append("  \"itemExitY\": ").append(itemExitY).append(",\n");
        sb.append("  \"profiles\": [\n");
        for (int pi = 0; pi < profiles.size(); pi++) {
            Profile p = profiles.get(pi);
            sb.append("    {\n");
            sb.append("      \"name\": \"").append(escJson(p.name)).append("\",\n");
            sb.append("      \"comboStr\": \"").append(escJson(p.comboStr)).append("\",\n");
            sb.append("      \"nukeMode\": ").append(p.nukeMode).append("\n");
            sb.append("    }");
            if (pi < profiles.size() - 1) sb.append(",");
            sb.append("\n");
        }
        sb.append("  ]\n}\n");
        try { Files.writeString(Path.of(CONFIG_FILE), sb.toString(), StandardCharsets.UTF_8); }
        catch (IOException e) { e.printStackTrace(); }
    }

    static void loadConfig() {
        if (!Files.exists(Path.of(CONFIG_FILE))) return;
        try {
            String json = Files.readString(Path.of(CONFIG_FILE), StandardCharsets.UTF_8);
            activeIdx = parseInt(between(json, "\"activeProfile\":", ","), 0);

            String uc = between(json, "\"uiColor\":", ",");
            if (uc != null) { try { ACCENT = Color.decode(uc.trim().replaceAll("^\"|\"$","")); } catch (Exception ignored) {} }

            String wh = between(json, "\"webhook\":", ",");
            if (wh != null) savedWebhook = wh.trim().replaceAll("^\"|\"$","").replace("\\\"","\"");
            String it = between(json, "\"items\":", ",");
            if (it != null) savedItems = it.trim().replaceAll("^\"|\"$","").replace("\\\"","\"");

            String gx = between(json, "\"itemGuiX\":",   ","); if (gx != null) itemGuiX   = parseInt(gx, -1);
            String gy = between(json, "\"itemGuiY\":",   ","); if (gy != null) itemGuiY   = parseInt(gy, -1);
            String sx = between(json, "\"searchBarX\":", ","); if (sx != null) searchBarX = parseInt(sx, -1);
            String sy = between(json, "\"searchBarY\":", ","); if (sy != null) searchBarY = parseInt(sy, -1);
            String ex = between(json, "\"itemExitX\":",  ","); if (ex != null) itemExitX  = parseInt(ex, -1);
            String ey = between(json, "\"itemExitY\":",  ","); if (ey != null) itemExitY  = parseInt(ey, -1);

            String arr = between(json, "\"profiles\":", null);
            if (arr != null) {
                int pos = 0;
                while (true) {
                    int s = arr.indexOf('{', pos); if (s < 0) break;
                    int e = matchingBrace(arr, s);  if (e < 0) break;
                    String blk  = arr.substring(s, e + 1);
                    String name = between(blk, "\"name\":", ",");
                    if (name != null) {
                        name = name.trim().replaceAll("^\"|\"$","").replace("\\\"","\"");
                        Profile p = new Profile(name);
                        String cs = between(blk, "\"comboStr\":", ",");
                        if (cs == null) cs = between(blk, "\"comboStr\":", "\n");
                        if (cs != null) p.comboStr = cs.trim().replaceAll("^\"|\"$","").replace("\\\"","\"");
                        String nm = between(blk, "\"nukeMode\":", "\n");
                        if (nm == null) nm = between(blk, "\"nukeMode\":", "}");
                        if (nm != null) p.nukeMode = nm.trim().startsWith("true");
                        profiles.add(p);
                    }
                    pos = e + 1;
                }
            }
        } catch (Exception e) { e.printStackTrace(); }
        if (profiles.isEmpty()) profiles.add(new Profile("Default"));
        activeIdx = Math.max(0, Math.min(activeIdx, profiles.size() - 1));
    }

    static void startGlobalHotkeyWatcher() {
        try {
            File flagFile = File.createTempFile("spm_f1_", ".txt");
            flagFile.deleteOnExit();
            Files.writeString(flagFile.toPath(), "0");

            File ps1 = File.createTempFile("spm_hotkey_", ".ps1");
            ps1.deleteOnExit();
            String fp = flagFile.getAbsolutePath().replace("\\", "\\\\");
            String body =
                "Add-Type @\"\n" +
                "using System;\nusing System.Runtime.InteropServices;\n" +
                "public class SPMHK {\n" +
                "    [DllImport(\"user32.dll\")] public static extern short GetAsyncKeyState(int v);\n" +
                "}\n" +
                "\"@ -Language CSharp\n" +
                "$prev=0\n" +
                "while($true){\n" +
                "    $cur=[SPMHK]::GetAsyncKeyState(0x70) -band 0x8000\n" +
                "    if($cur -ne 0 -and $prev -eq 0){\n" +
                "        Set-Content -Path \"" + fp + "\" -Value ([DateTimeOffset]::UtcNow.ToUnixTimeMilliseconds())\n" +
                "    }\n" +
                "    $prev=$cur\n" +
                "    Start-Sleep -Milliseconds 40\n" +
                "}\n";
            Files.writeString(ps1.toPath(), body, StandardCharsets.UTF_8);

            ProcessBuilder pb = new ProcessBuilder(
                "powershell.exe", "-ExecutionPolicy", "Bypass",
                "-WindowStyle", "Hidden", "-NonInteractive",
                "-File", ps1.getAbsolutePath());
            pb.redirectErrorStream(true);
            Process proc = pb.start();
            new Thread(() -> {
                try { proc.getInputStream().transferTo(OutputStream.nullOutputStream()); }
                catch (Exception ignored) {}
            }).start();

            final long[] lastTs = {0L};
            Thread poll = new Thread(() -> {
                while (true) {
                    try {
                        Thread.sleep(80);
                        String val = Files.readString(flagFile.toPath()).trim();
                        if (val.isEmpty()) continue;
                        long ts = Long.parseLong(val);
                        if (ts != lastTs[0]) {
                            lastTs[0] = ts;
                            SwingUtilities.invokeLater(() -> {
                                if (comboToggle != null) comboToggle.doClick();
                            });
                        }
                    } catch (Exception ignored) {}
                }
            });
            poll.setDaemon(true);
            poll.start();
        } catch (Exception e) { e.printStackTrace(); }
    }


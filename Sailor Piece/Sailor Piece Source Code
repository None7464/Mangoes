    static Profile activeProfile() { return profiles.get(activeIdx); }

    static void applyProfileToUI() {
        Profile p = activeProfile();
        if (comboField != null) {
            comboField.setText(p.comboStr);
            comboField.setEnabled(!p.nukeMode);
            comboField.setBackground(p.nukeMode ? new Color(16, 24, 8) : new Color(28, 44, 14));
        }
        if (nukeModeBox != null) nukeModeBox.setSelected(p.nukeMode);
    }

    static void doAddProfile() {
        String name = JOptionPane.showInputDialog(frame, "New profile name:", "Add Profile", JOptionPane.PLAIN_MESSAGE);
        if (name == null || name.trim().isEmpty()) return;
        name = name.trim();
        for (Profile p : profiles) if (p.name.equalsIgnoreCase(name)) {
            JOptionPane.showMessageDialog(frame, "Name already exists.", "Duplicate", JOptionPane.WARNING_MESSAGE); return;
        }
        Profile np = activeProfile().copy(name);
        profiles.add(np);
        activeIdx = profiles.size() - 1;
        profileBox.addItem(np.name);
        profileBox.setSelectedIndex(activeIdx);
        applyProfileToUI();
    }

    static void doDeleteProfile() {
        if (profiles.size() <= 1) {
            JOptionPane.showMessageDialog(frame, "Must keep at least one profile.", "Cannot Delete", JOptionPane.WARNING_MESSAGE); return;
        }
        int c = JOptionPane.showConfirmDialog(frame, "Delete \"" + activeProfile().name + "\"?", "Delete", JOptionPane.YES_NO_OPTION);
        if (c != JOptionPane.YES_OPTION) return;
        profiles.remove(activeIdx);
        profileBox.removeItemAt(activeIdx);
        activeIdx = Math.max(0, activeIdx - 1);
        profileBox.setSelectedIndex(activeIdx);
        applyProfileToUI();
    }

    static void focusRobloxThenStart() {
        new Thread(() -> {
            try {
                File ps1 = File.createTempFile("spm_focus_", ".ps1");
                ps1.deleteOnExit();
                String body =
                    "Add-Type @\"\n" +
                    "using System;using System.Runtime.InteropServices;\n" +
                    "public class RFocus{\n" +
                    "  [DllImport(\"user32.dll\")] public static extern bool SetForegroundWindow(IntPtr h);\n" +
                    "  [DllImport(\"user32.dll\")] public static extern bool ShowWindow(IntPtr h,int n);\n" +
                    "}\n" +
                    "\"@ -Language CSharp\n" +
                    "$p=Get-Process|Where-Object{$_.MainWindowTitle -like '*Roblox*'}|Select-Object -First 1\n" +
                    "if($p){[RFocus]::ShowWindow($p.MainWindowHandle,9);[RFocus]::SetForegroundWindow($p.MainWindowHandle)}\n";
                Files.writeString(ps1.toPath(), body, StandardCharsets.UTF_8);
                new ProcessBuilder("powershell.exe", "-ExecutionPolicy", "Bypass",
                    "-WindowStyle", "Hidden", "-NonInteractive", "-File", ps1.getAbsolutePath())
                    .start().waitFor();
            } catch (Exception ignored) {}
            sleepMs(2500);
            if (comboToggle != null && comboToggle.isSelected()) startCombo();
        }).start();
    }

    static List<ComboStep> parseCombo(String raw) {
        List<ComboStep> steps = new ArrayList<>();
        for (String part : raw.split(">")) {
            part = part.trim();
            if (part.isEmpty()) continue;
            String[] tokens = part.split("\\s+");
            if (tokens.length == 0) continue;
            String first = tokens[0].trim();
            try {
                steps.add(new ComboStep(null, (long)(Double.parseDouble(first) * 1000))); continue;
            } catch (NumberFormatException ignored) {}
            long delay = 0;
            if (tokens.length >= 2) {
                try { delay = (long)(Double.parseDouble(tokens[1]) * 1000); } catch (Exception ignored) {}
            }
            steps.add(new ComboStep(first.toUpperCase(), delay));
        }
        return steps;
    }

    static void startCombo() {
        comboRunning = true;
        comboThread = new Thread(() -> {
            while (comboRunning) {
                Profile p = activeProfile();
                if (p.nukeMode) {
                    int[] vks = { KeyEvent.VK_1, KeyEvent.VK_F, KeyEvent.VK_2, KeyEvent.VK_F };
                    for (int vk : vks) {
                        if (!comboRunning) break;
                        robot.keyPress(vk); robot.keyRelease(vk); sleepMs(1);
                    }
                } else {
                    List<ComboStep> steps = parseCombo(p.comboStr);
                    if (steps.isEmpty()) { sleepMs(100); continue; }
                    for (ComboStep step : steps) {
                        if (!comboRunning) break;
                        if (step.key != null) pressKey(step.key);
                        if (step.delayMs > 0) sleepMs(step.delayMs);
                    }
                }
            }
        });
        comboThread.setDaemon(true);
        comboThread.start();
    }

    static void stopCombo() {
        comboRunning = false;
        if (comboThread != null) comboThread.interrupt();
        SwingUtilities.invokeLater(() -> {
            if (comboToggle != null && comboToggle.isSelected()) {
                comboToggle.setSelected(false);
                comboToggle.setText("OFF  (F1)");
            }
        });
    }

    static void pressKey(String key) {
        int vk = strToVK(key);
        if (vk == -1) return;
        robot.keyPress(vk); sleepMs(35); robot.keyRelease(vk);
    }

    static int strToVK(String key) {
        if (key == null || key.isEmpty()) return -1;
        switch (key) {
            case "M1":    return KeyEvent.VK_1;
            case "M2":    return KeyEvent.VK_2;
            case "SPACE": return KeyEvent.VK_SPACE;
            case "ENTER": return KeyEvent.VK_ENTER;
            case "TAB":   return KeyEvent.VK_TAB;
            case "SHIFT": return KeyEvent.VK_SHIFT;
            case "CTRL":  return KeyEvent.VK_CONTROL;
            case "ALT":   return KeyEvent.VK_ALT;
            case "F1":  return KeyEvent.VK_F1;
            case "F2":  return KeyEvent.VK_F2;
            case "F3":  return KeyEvent.VK_F3;
            case "F4":  return KeyEvent.VK_F4;
            case "F5":  return KeyEvent.VK_F5;
            case "F6":  return KeyEvent.VK_F6;
            case "F7":  return KeyEvent.VK_F7;
            case "F8":  return KeyEvent.VK_F8;
            case "F9":  return KeyEvent.VK_F9;
            case "F10": return KeyEvent.VK_F10;
            case "F11": return KeyEvent.VK_F11;
            case "F12": return KeyEvent.VK_F12;
            default:
                if (key.length() == 1) {
                    int vk = KeyEvent.getExtendedKeyCodeForChar(key.charAt(0));
                    return vk == KeyEvent.VK_UNDEFINED ? -1 : vk;
                }
                return -1;
        }
    }
    
    static void startWebhookTimer() {
        stopWebhookTimer();
        long ms = parseTimerInput(timerField.getText().trim());
        if (ms <= 0) {
            JOptionPane.showMessageDialog(frame, "Use format: 7h  30m  45s", "Bad Timer", JOptionPane.WARNING_MESSAGE);
            return;
        }
        timerIntervalMs = ms;
        scheduleTick();
    }

    static void scheduleTick() {
        countdownEndMs = System.currentTimeMillis() + timerIntervalMs;
        countdownSwingTimer = new javax.swing.Timer(500, null);
        countdownSwingTimer.addActionListener(e -> {
            long rem = countdownEndMs - System.currentTimeMillis();
            if (rem <= 0) {
                timerCountdownLbl.setText("Firing...");
                timerCountdownLbl.setForeground(ACCENT);
                countdownSwingTimer.stop();
                new Thread(() -> {
                    boolean wasRunning = comboRunning;
                    if (wasRunning) stopCombo();
                    sleepMs(300);
                    runItemWebhook();
                    // Restart combo if it was running
                    if (wasRunning) {
                        SwingUtilities.invokeLater(() -> {
                            comboToggle.setSelected(true);
                            comboToggle.setText("ON   (F1)");
                        });
                        focusRobloxThenStart();
                    }
                    // Loop timer
                    SwingUtilities.invokeLater(() -> {
                        if (timerIntervalMs > 0) {
                            timerCountdownLbl.setText("Waiting...");
                            timerCountdownLbl.setForeground(DIM);
                            scheduleTick();
                        }
                    });
                }).start();
            } else {
                long h = rem / 3_600_000, m = (rem % 3_600_000) / 60_000, s = (rem % 60_000) / 1_000;
                timerCountdownLbl.setText(h > 0 ? h+"h "+m+"m "+s+"s" : m > 0 ? m+"m "+s+"s" : s+"s");
                timerCountdownLbl.setForeground(FG);
            }
        });
        countdownSwingTimer.start();
    }

    static void stopWebhookTimer() {
        if (countdownSwingTimer != null) countdownSwingTimer.stop();
        if (timerCountdownLbl != null) { timerCountdownLbl.setText("--"); timerCountdownLbl.setForeground(DIM); }
        countdownEndMs = -1; timerIntervalMs = -1;
    }

    static long parseTimerInput(String s) {
        if (s.isEmpty()) return -1;
        try {
            char unit = Character.toLowerCase(s.charAt(s.length() - 1));
            long val  = Long.parseLong(s.substring(0, s.length() - 1).trim());
            if (unit == 'h') return val * 3_600_000L;
            if (unit == 'm') return val * 60_000L;
            if (unit == 's') return val * 1_000L;
        } catch (Exception ignored) {}
        return -1;
    }


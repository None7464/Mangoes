    static void startRuntimeTimer() {
        runtimeSwingTimer = new javax.swing.Timer(1000, e -> {
            long elapsed = System.currentTimeMillis() - startTimeMs;
            long h = elapsed / 3_600_000;
            long m = (elapsed % 3_600_000) / 60_000;
            long s = (elapsed % 60_000) / 1_000;
            runtimeLbl.setText(
                h > 0 ? "Runtime: " + h + "h " + m + "m " + s + "s"
                      : m > 0 ? "Runtime: " + m + "m " + s + "s"
                              : "Runtime: " + s + "s");
        });
        runtimeSwingTimer.start();
    }

